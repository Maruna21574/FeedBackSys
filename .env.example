# --- Aplikacia ---
NODE_ENV=development
PORT=3000
# Verejna URL behu aplikacie (pouziva sa v emailoch a snippet odkazoch)
APP_URL=http://localhost:3000

# --- Databaza (SQLite) ---
# Pozn.: cesta je relativna k prisma/schema.prisma, takze vysledny subor je prisma/dev.db
DATABASE_URL="file:./dev.db"

# --- Session / bezpecnost ---
# Vygenerujte dlhy nahodny retazec, napr.: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# --- Email (admin notifikacie) ---
# Adresa, na ktoru pride suhrn po odoslani vsetkych pripomienok
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# SMTP nastavenia (ak su prazdne, email sa len zaloguje do konzoly)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Feedback Tool <no-reply@example.com>"

# --- Widget ---
# Povolene originy pre widget API (* = vsetky, alebo zoznam oddeleny ciarkou)
WIDGET_CORS_ORIGIN=*

# --- Upload ---
MAX_UPLOAD_SIZE_MB=5
