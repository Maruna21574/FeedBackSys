<div class="page-header">
  <div>
    <h1>Klienti</h1>
    <p class="subtitle">Správa klientov a ich prístupových údajov do klientského portálu.</p>
  </div>
</div>

<div class="detail-grid" style="grid-template-columns: 2fr 1fr;">
  <div>
    <% if (clients.length === 0) { %>
      <div class="card">
        <div class="empty-state">Zatiaľ neboli vytvorení žiadni klienti.</div>
      </div>
    <% } else { %>
      <div class="card">
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Názov</th>
                <th>Email</th>
                <th>Projekty</th>
                <th>Prihlasovacie údaje</th>
                <th>Vytvorené</th>
              </tr>
            </thead>
            <tbody>
              <% clients.forEach(function (client) { %>
                <tr>
                  <td><%= client.name %></td>
                  <td><%= client.email %></td>
                  <td>
                    <% if (client.projects.length === 0) { %>
                      <span class="text-muted">žiadne</span>
                    <% } else { %>
                      <% client.projects.forEach(function (p, i) { %>
                        <a href="/admin/projects/<%= p.id %>"><%= p.name %></a><%= i < client.projects.length - 1 ? ', ' : '' %>
                      <% }) %>
                    <% } %>
                  </td>
                  <td>
                    <% if (client.users.length === 0) { %>
                      <span class="text-muted">-</span>
                    <% } else { %>
                      <% client.users.forEach(function (u) { %>
                        <div class="mono text-sm"><%= u.email %></div>
                      <% }) %>
                    <% } %>
                  </td>
                  <td class="text-sm text-muted"><%= new Date(client.createdAt).toLocaleDateString('sk-SK') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>

  <div>
    <div class="card">
      <div class="card-header"><h3>Nový klient</h3></div>
      <form method="post" action="/admin/clients">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label for="name">Názov klienta</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="form-group">
          <label for="email">Prihlasovací email</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-group">
          <label for="password">Heslo pre klientský portál</label>
          <input type="password" id="password" name="password" required minlength="6" />
          <div class="form-hint">Aspoň 6 znakov. Klient si ho môže zmeniť neskôr.</div>
        </div>
        <div class="form-group">
          <label for="note">Interná poznámka (nepovinné)</label>
          <textarea id="note" name="note" rows="3"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary w-full">Vytvoriť klienta</button>
        </div>
      </form>
    </div>
  </div>
</div>
